---
const steps = [
  { n: '01', t: 'Du sender forespørgsel', b: 'Udfyld formularen eller ring direkte. Vi vender tilbage på hverdage.' },
  { n: '02', t: 'Besigtigelse', b: 'Vi kører ud og ser taget. Vi taler projektet igennem og afdækker behovet.' },
  { n: '03', t: 'Uforpligtende tilbud', b: 'Du får et tilbud på arbejdet. Du forpligter dig til ingenting før du skriver under.' },
  { n: '04', t: 'Vi går i gang', b: 'Levering indenfor 90 dage fra projektstart til færdigt tag. Du ved altid hvor vi er i processen.' },
  { n: '05', t: 'Aflevering', b: 'Gennemgang af taget, oplæring i vedligehold og udlevering af dokumentation.' },
]
---

<section class="v5-process" id="proces">
  <div class="v5-p-container">
    <div class="v5-p-head">
      <span class="v5-eyebrow">Sådan kører det</span>
      <h2 class="v5-h2">
        Fra forespørgsel til <span class="v5-h2-italic">færdigt tag</span> — 5 enkle trin.
      </h2>
    </div>

    <div class="v5-p-timeline">
      {steps.map((s, i) => (
        <div class="v5-p-step">
          <div class="v5-p-circle">{s.n}</div>
          <div class="v5-p-card">
            <h3 class="v5-p-title">{s.t}</h3>
            <p class="v5-p-body">{s.b}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .v5-process { background: #fbf9f8; padding: 96px 0; }
  .v5-p-container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  .v5-p-head { text-align: center; max-width: 720px; margin: 0 auto 56px; }
  .v5-eyebrow { font-family: var(--font-label); font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase; color: #6f4315; display: block; margin-bottom: 16px; }
  .v5-h2 { font-family: var(--font-headline); font-size: clamp(1.75rem, 4vw, 2.5rem); line-height: 1.2; color: #1b1c1c; margin: 0; font-weight: 500; }
  .v5-h2-italic { font-style: italic; color: #6f4315; }

  .v5-p-timeline {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    position: relative;
  }
  .v5-p-step {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 20px;
    align-items: start;
    position: relative;
  }
  .v5-p-step:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 31px;
    top: 64px;
    bottom: -16px;
    width: 2px;
    background: rgba(111,67,21,0.2);
  }
  .v5-p-circle {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: #6f4315;
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-headline);
    font-style: italic;
    font-size: 1.5rem;
    box-shadow: 0 8px 24px rgba(111,67,21,0.25);
  }
  .v5-p-card {
    background: #fff;
    padding: 20px 24px;
    border-radius: 12px;
    border: 1px solid rgba(111,67,21,0.12);
    box-shadow: 0 4px 16px rgba(0,0,0,0.04);
  }
  .v5-p-title { font-family: var(--font-body); font-weight: 700; font-size: 1.1rem; color: #1b1c1c; margin: 0 0 8px; }
  .v5-p-body { font-family: var(--font-body); font-size: 0.95rem; line-height: 1.65; color: #51443a; margin: 0; }
</style>
</content>
</invoke>