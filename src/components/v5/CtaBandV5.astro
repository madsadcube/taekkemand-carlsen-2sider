---
// V5 CTA band — full-width orange-brun blok før kontakt
---

<section class="v5-band">
  <div class="v5-band-container">
    <div class="v5-band-content">
      <h2 class="v5-band-h2">
        Klar til at få <span class="v5-band-italic">styr på taget?</span>
      </h2>
      <p class="v5-band-sub">
        Vi kører ud og besigter taget. Du får et uforpligtende tilbud — du forpligter dig til ingenting.
      </p>
      <div class="v5-band-cta">
        <a href="#kontakt" class="v5-band-btn">Få et uforpligtende tilbud</a>
        <a href="tel:+4524248080" class="v5-band-phone">eller ring direkte: <strong>24 24 80 80</strong></a>
      </div>
    </div>
  </div>
</section>

<style>
  .v5-band { background: linear-gradient(135deg, #6f4315 0%, #51331a 100%); padding: 80px 0; position: relative; overflow: hidden; }
  .v5-band::before {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(255,220,193,0.15) 0%, transparent 70%);
  }
  .v5-band-container { max-width: 1100px; margin: 0 auto; padding: 0 24px; position: relative; }
  .v5-band-content { text-align: center; max-width: 720px; margin: 0 auto; }
  .v5-band-h2 { font-family: var(--font-headline); font-size: clamp(2rem, 4.5vw, 3rem); line-height: 1.15; color: #fff; margin: 0 0 16px; font-weight: 500; }
  .v5-band-italic { font-style: italic; color: #ffdcc1; }
  .v5-band-sub { font-family: var(--font-body); font-size: 1.1rem; line-height: 1.6; color: rgba(255,255,255,0.9); margin: 0 0 32px; }
  .v5-band-cta { display: flex; flex-wrap: wrap; gap: 20px; justify-content: center; align-items: center; }
  .v5-band-btn { background: #fff; color: #6f4315; padding: 18px 36px; border-radius: 10px; font-family: var(--font-body); font-weight: 700; font-size: 1.05rem; box-shadow: 0 8px 24px rgba(0,0,0,0.2); transition: transform 0.3s; }
  .v5-band-btn:hover { transform: translateY(-2px); }
  .v5-band-phone { color: #ffdcc1; font-family: var(--font-body); font-size: 1rem; }
  .v5-band-phone strong { color: #fff; }
</style>
</content>
</invoke>