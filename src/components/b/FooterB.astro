---
import { cities } from '../../data/cities'
const footerCities = cities.filter((c) => c.region === 'Nordsjælland')
---

<footer class="b-footer">
  <div class="b-f-container">
    <div class="b-f-grid">
      <div>
        <div class="b-f-brand">Tækkemand Carlsen</div>
        <p class="b-f-tag">Tækkefirma på Nordsjælland med 15+ års erfaring. Forsikret hos Alm. Brand op til 12 mio. kr.</p>
      </div>

      <div>
        <div class="b-f-h">Ydelser</div>
        <ul>
          <li><a href="/tagdaekning/nyt-straatag/">Nyt stråtag</a></li>
          <li><a href="/tagdaekning/renovering-af-straatag/">Renovering</a></li>
          <li><a href="/tagdaekning/monning-til-straatag/">Mønning</a></li>
          <li><a href="/tagdaekning/aldebehandling-af-straatag/">Algebehandling</a></li>
        </ul>
      </div>

      <div>
        <div class="b-f-h">Områder</div>
        <ul>
          {footerCities.map((c) => (
            <li><a href={`/${c.slug}/`}>{c.name}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <div class="b-f-h">Kontakt</div>
        <a href="tel:+4524248080" class="b-f-phone">24 24 80 80</a>
        <a href="mailto:post@taekkemandcarlsen.dk" class="b-f-email">post@taekkemandcarlsen.dk</a>
        <div class="b-f-hours">Hverdage 8–16</div>
        <div class="b-f-social">
          <a href="https://facebook.com/taekkemandcarlsen" target="_blank" rel="noopener noreferrer" aria-label="Besøg vores Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
          </a>
          <a href="https://www.instagram.com/taekkemandcarlsen" target="_blank" rel="noopener noreferrer" aria-label="Følg os på Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.336 3.608 1.311.975.975 1.249 2.242 1.311 3.608.058 1.266.069 1.646.069 4.85 0 3.205-.012 3.584-.069 4.85-.062 1.366-.336 2.633-1.311 3.608-.975.975-2.242 1.249-3.608 1.311-1.266.058-1.645.07-4.85.07-3.204 0-3.584-.012-4.85-.07-1.366-.062-2.633-.336-3.608-1.311-.975-.975-1.249-2.242-1.311-3.608C2.175 15.747 2.163 15.368 2.163 12s.012-3.584.07-4.85c.062-1.366.336-2.633 1.311-3.608.975-.975 2.242-1.249 3.608-1.311C8.416 2.175 8.796 2.163 12 2.163zm0 1.838c-3.142 0-3.515.011-4.755.068-1.066.049-1.645.226-2.03.376-.51.198-.874.435-1.257.818-.383.383-.62.747-.818 1.257-.15.385-.327.964-.376 2.03-.057 1.24-.068 1.613-.068 4.755 0 3.143.011 3.515.068 4.755.049 1.066.226 1.645.376 2.03.198.51.435.874.818 1.257.383.383.747.62 1.257.818.385.15.964.327 2.03.376 1.24.057 1.613.068 4.755.068 3.143 0 3.515-.011 4.755-.068 1.066-.049 1.645-.226 2.03-.376.51-.198.874-.435 1.257-.818.383-.383.62-.747.818-1.257.15-.385.327-.964.376-2.03.057-1.24.068-1.613.068-4.755 0-3.142-.011-3.515-.068-4.755-.049-1.066-.226-1.645-.376-2.03-.198-.51-.435-.874-.818-1.257-.383-.383-.747-.62-1.257-.818-.385-.15-.964-.327-2.03-.376C15.515 4.012 15.143 4.001 12 4.001zm0 3.13a4.87 4.87 0 110 9.738 4.87 4.87 0 010-9.738zm0 8.03a3.16 3.16 0 100-6.32 3.16 3.16 0 000 6.32zm6.196-8.234a1.137 1.137 0 11-2.274 0 1.137 1.137 0 012.274 0z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="b-f-foot">
      <span>© 2026 Tækkemand Carlsen &amp; Tækkekollektivet</span>
      <span>CVR 44410976 · Nørretorv 30, 4100 Ringsted</span>
    </div>
  </div>
</footer>

<style>
  .b-footer { background: #1b1c1c; color: #fdf8ee; padding: 64px 0 24px; }
  .b-f-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
  .b-f-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    margin-bottom: 48px;
  }
  .b-f-brand { font-family: var(--font-headline); font-style: italic; font-size: 1.75rem; color: #fff; margin-bottom: 12px; }
  .b-f-tag { font-family: var(--font-body); font-size: 0.95rem; color: rgba(253,248,238,0.7); margin: 0 0 12px; max-width: 320px; line-height: 1.5; }
  .b-f-stars { color: #d4a017; font-family: var(--font-body); font-weight: 700; font-size: 0.95rem; }

  .b-f-h { font-family: var(--font-label); font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase; color: #ffdcc1; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid rgba(255,220,193,0.2); }
  .b-footer ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .b-footer ul a { font-family: var(--font-body); font-size: 0.95rem; color: rgba(253,248,238,0.8); transition: color 0.3s; }
  .b-footer ul a:hover { color: #fff; }
  .b-f-phone { display: block; font-family: var(--font-headline); font-style: italic; font-size: 1.5rem; color: #fff !important; margin-bottom: 8px; }
  .b-f-email { display: block; font-family: var(--font-body); font-size: 0.95rem; color: rgba(253,248,238,0.8) !important; margin-bottom: 8px; }
  .b-f-hours { font-family: var(--font-label); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: #ffdcc1; }

  .b-f-social { display: flex; gap: 12px; margin-top: 16px; }
  .b-f-social a {
    display: inline-flex; align-items: center; justify-content: center;
    width: 36px; height: 36px;
    border-radius: 50%;
    background: rgba(255,220,193,0.1);
    color: #ffdcc1;
    transition: background 0.3s, color 0.3s, transform 0.2s;
  }
  .b-f-social a:hover { background: #6f4315; color: #fff; transform: translateY(-2px); }

  .b-f-foot {
    padding-top: 24px;
    border-top: 1px solid rgba(255,220,193,0.15);
    display: flex; flex-wrap: wrap; justify-content: space-between; gap: 12px;
    font-family: var(--font-label);
    font-size: 11px; letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,220,193,0.5);
  }

  @media (min-width: 768px) { .b-f-grid { grid-template-columns: 2fr 1fr 1fr 1fr; } }
</style>
</content>
</invoke>