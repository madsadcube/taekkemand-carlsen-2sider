---
// B Social proof bar — lige under hero. Lys cream, ikoner, refined typografi.
---

<section class="b-proof" aria-label="Sociale beviser">
  <div class="b-proof-container">
    <div class="b-proof-stat">
      <div class="b-proof-icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 8v4l3 2"/>
          <circle cx="12" cy="12" r="10"/>
        </svg>
      </div>
      <div>
        <div class="b-proof-num">15+ år</div>
        <div class="b-proof-label">Tækkeerfaring</div>
      </div>
    </div>

    <span class="b-proof-divider" aria-hidden="true"></span>

    <div class="b-proof-stat">
      <div class="b-proof-icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="5" width="18" height="16" rx="1"/>
          <path d="M8 3v4M16 3v4M3 11h18"/>
          <path d="M9 16l2 2 4-4"/>
        </svg>
      </div>
      <div>
        <div class="b-proof-num">90 dage</div>
        <div class="b-proof-label">Garanteret leveringstid</div>
      </div>
    </div>

    <span class="b-proof-divider" aria-hidden="true"></span>

    <div class="b-proof-stat">
      <div class="b-proof-icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L3 7v5c0 5 3.5 8.5 9 10 5.5-1.5 9-5 9-10V7l-9-5z"/>
          <path d="M9 12l2 2 4-4"/>
        </svg>
      </div>
      <div>
        <div class="b-proof-num">12 mio. kr</div>
        <div class="b-proof-label">Forsikret hos Alm. Brand</div>
      </div>
    </div>

    <span class="b-proof-divider" aria-hidden="true"></span>

    <div class="b-proof-stat">
      <div class="b-proof-icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1118 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
      </div>
      <div>
        <div class="b-proof-num">Nordsjælland</div>
        <div class="b-proof-label">Vores primære område</div>
      </div>
    </div>
  </div>
</section>

<style>
  .b-proof {
    background: #f4ede2;
    color: #1a1310;
    padding: 32px 0 40px;
    position: relative;
  }
  .b-proof::before {
    content: '';
    position: absolute;
    top: 0; left: 8%; right: 8%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(160,79,27,0.25), transparent);
  }
  .b-proof-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: center;
  }
  .b-proof-stat {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .b-proof-icon {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: rgba(160,79,27,0.08);
    color: #a04f1b;
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: background 0.3s, color 0.3s;
  }
  .b-proof-stat:hover .b-proof-icon {
    background: rgba(160,79,27,0.18);
    color: #7a3a13;
  }
  .b-proof-num {
    font-family: var(--font-headline);
    font-size: 1.35rem;
    color: #1a1310;
    line-height: 1.1;
    font-weight: 500;
  }
  .b-proof-label {
    font-family: var(--font-label);
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #6b5a4d;
    margin-top: 4px;
  }
  .b-proof-divider {
    display: none;
    width: 1px;
    height: 44px;
    background: rgba(160,79,27,0.18);
    justify-self: center;
  }

  @media (min-width: 768px) {
    .b-proof-container {
      grid-template-columns: 1fr 1px 1fr 1px 1fr 1px 1fr;
      gap: 28px;
    }
    .b-proof-divider { display: block; }
  }
</style>
