---
// B Hero — editorial heritage layout, 2-col grid (text venstre, foto-artefakt højre)
// Ingen baggrunds-overlay. Foto som ægte element. Magazine-stil med polaroid + EST stempel.
---

<section class="b-hero">
  <div class="b-hero-container">

    <div class="b-hero-text">
      <div class="b-eyebrow-proof">
        <span class="b-stars" aria-label="4.9 stjerner ud af 5">★★★★★</span>
        <strong>4.9/5</strong>
        <span class="b-proof-sep">·</span>
        <span>50+ kunder på Nordsjælland</span>
      </div>

      <h1 class="b-h1">
        Lokal tækkemand i Nordsjælland<br/>
        <span class="b-h1-italic">— smukt og holdbart håndværk</span>
      </h1>

      <p class="b-sub">
        Få et uforpligtende tilbud på nyt stråtag, mønning, reparation eller algebehandling.
        Vi servicerer primært private kunder på Nordsjælland.
      </p>

      <div class="b-cta">
        <a href="#kontakt" class="b-btn-primary">
          Få uforpligtende tilbud
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href="tel:+4524248080" class="b-phone-link">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          <span>Eller ring <strong>24 24 80 80</strong></span>
        </a>
      </div>
    </div>

    <aside class="b-hero-art" aria-hidden="true">
      <figure class="b-photo">
        <img src="/img/straatag1-hero.jpg" alt="" loading="eager" fetchpriority="high"/>
      </figure>
    </aside>

  </div>
</section>

<style>
  .b-hero {
    background: #f4ede2;
    color: #1a1310;
    padding: 128px 0 32px;
    position: relative;
    overflow: hidden;
  }
  .b-hero-container {
    position: relative;
    max-width: 1400px;
    margin: 0 auto;
    padding: 32px 24px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px;
    align-items: center;
  }

  /* --- TEXT --- */
  .b-hero-text { max-width: 540px; }

  .b-eyebrow-proof {
    display: inline-flex; flex-wrap: wrap; align-items: center; gap: 10px;
    font-family: var(--font-body);
    font-size: 0.92rem;
    color: #51443a;
    padding-bottom: 14px;
    margin-bottom: 28px;
    border-bottom: 1px solid rgba(160,79,27,0.25);
  }
  .b-eyebrow-proof strong { color: #1a1310; font-weight: 700; }

  .b-h1 {
    font-family: var(--font-headline);
    font-size: clamp(2.4rem, 5.2vw, 4rem);
    line-height: 1.02;
    color: #1a1310;
    margin: 0 0 28px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .b-h1-italic {
    display: inline-block;
    padding-top: 8px;
    font-style: italic;
    color: #a04f1b;
    font-weight: 400;
  }

  .b-sub {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.65;
    color: #51443a;
    margin: 0 0 32px;
    max-width: 460px;
  }

  .b-stars { color: #c39538; letter-spacing: 2px; font-size: 1rem; }
  .b-proof-sep { color: rgba(81,68,58,0.45); }

  .b-cta { display: flex; flex-wrap: wrap; align-items: center; gap: 16px 24px; }
  .b-btn-primary {
    display: inline-flex; align-items: center; gap: 10px;
    background: #1a1310;
    color: #f4ede2;
    padding: 18px 28px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.01em;
    border-radius: 0;
    transition: background 0.3s, transform 0.3s;
  }
  .b-btn-primary:hover { background: #a04f1b; transform: translateY(-2px); }
  .b-btn-primary svg { transition: transform 0.3s; }
  .b-btn-primary:hover svg { transform: translateX(4px); }

  .b-phone-link {
    display: inline-flex; align-items: center; gap: 8px;
    color: #1a1310;
    font-family: var(--font-body);
    font-size: 1rem;
    transition: color 0.2s;
  }
  .b-phone-link strong { font-weight: 700; font-size: 1.1rem; border-bottom: 1px solid currentColor; padding-bottom: 1px; }
  .b-phone-link:hover { color: #a04f1b; }
  .b-phone-link svg { color: #a04f1b; flex-shrink: 0; }

  /* --- ART (foto-side) --- */
  .b-hero-art {
    position: relative;
    display: none; /* mobile: skjul, vises på desktop */
  }

  .b-stamp {
    position: absolute;
    top: -28px; right: -28px;
    width: 100px; height: 100px;
    border: 2px solid #a04f1b;
    border-radius: 50%;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    color: #a04f1b;
    background: rgba(244,237,226,0.92);
    transform: rotate(-7deg);
    z-index: 20;
  }
  .b-stamp::before {
    content: '';
    position: absolute; inset: 4px;
    border: 1px solid rgba(160,79,27,0.45);
    border-radius: 50%;
  }
  .b-stamp-pre {
    font-family: var(--font-label);
    font-size: 10px; letter-spacing: 0.3em;
    text-transform: uppercase;
  }
  .b-stamp-year {
    font-family: var(--font-headline);
    font-size: 1.75rem; font-style: italic;
    line-height: 1; margin-top: 2px;
  }

  .b-photo {
    margin: 0;
    width: 100%;
    aspect-ratio: 4/5;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(26,19,16,0.22);
    position: relative;
  }
  .b-photo img {
    display: block; width: 100%; height: 100%;
    object-fit: cover;
    filter: contrast(1.02) saturate(1.05);
  }
  .b-photo-meta {
    display: flex; align-items: baseline; gap: 14px;
    margin-top: 18px;
    padding-top: 12px;
    border-top: 1px solid rgba(160,79,27,0.3);
  }
  .b-photo-num {
    font-family: var(--font-headline);
    font-style: italic;
    font-size: 1.3rem;
    color: #a04f1b;
    line-height: 1;
  }
  .b-photo-cap {
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: #51443a;
    letter-spacing: 0.02em;
  }

  @media (max-width: 1023px) {
    .b-hero-text { margin: 0 auto; text-align: left; }
  }

  @media (min-width: 1024px) {
    .b-hero { padding: 144px 0 48px; }
    .b-hero-container {
      grid-template-columns: 5fr 7fr;
      gap: 80px;
      padding: 0 56px;
    }
    .b-hero-art { display: block; }
    .b-stamp { width: 124px; height: 124px; top: -40px; right: -32px; }
  }
</style>
