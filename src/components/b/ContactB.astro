---
---

<section class="b-contact" id="kontakt">
  <div class="b-c-container">
    <div class="b-c-grid">
      <div class="b-c-text">
        <span class="b-eyebrow">Skriv til os</span>
        <h2 class="b-h2">
          Få et <span class="b-h2-italic">uforpligtende tilbud</span>.
        </h2>
        <p class="b-c-sub">
          Beskriv dit projekt — så vender vi tilbage med næste skridt. Du forpligter dig til ingenting.
        </p>

        <div class="b-c-promises">
          <div class="b-c-promise">
            <div class="b-c-check"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></div>
            <div>
              <div class="b-c-promise-t">Vi besigter taget</div>
              <div class="b-c-promise-m">Uforpligtende — vi kører ud.</div>
            </div>
          </div>
          <div class="b-c-promise">
            <div class="b-c-check"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></div>
            <div>
              <div class="b-c-promise-t">Skriftligt tilbud</div>
              <div class="b-c-promise-m">Klar overblik over hvad arbejdet koster.</div>
            </div>
          </div>
          <div class="b-c-promise">
            <div class="b-c-check"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></div>
            <div>
              <div class="b-c-promise-t">Levering inden 90 dage</div>
              <div class="b-c-promise-m">Fra projektstart til færdigt tag.</div>
            </div>
          </div>
        </div>

        <div class="b-c-direct">
          <a href="tel:+4524248080" class="b-c-direct-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <div>
              <div class="b-c-direct-num">24 24 80 80</div>
              <div class="b-c-direct-meta">Hverdage 8–16</div>
            </div>
          </a>
        </div>
      </div>

      <form class="b-c-form" action="https://formspree.io/f/your-id" method="POST">
        <div class="b-c-field">
          <label for="b-name">Navn</label>
          <input id="b-name" name="name" type="text" required/>
        </div>
        <div class="b-c-field-row">
          <div class="b-c-field">
            <label for="b-tlf">Telefon</label>
            <input id="b-tlf" name="phone" type="tel"/>
          </div>
          <div class="b-c-field">
            <label for="b-email">Email</label>
            <input id="b-email" name="email" type="email" required/>
          </div>
        </div>
        <div class="b-c-field">
          <label for="b-addr">Adresse på taget</label>
          <input id="b-addr" name="address" type="text"/>
        </div>
        <div class="b-c-field">
          <label for="b-svc">Hvad drejer det sig om?</label>
          <select id="b-svc" name="service">
            <option>Nyt stråtag</option>
            <option>Renovering / reparation</option>
            <option>Mønning</option>
            <option>Algebehandling</option>
            <option>Akut skade</option>
            <option>Andet</option>
          </select>
        </div>
        <div class="b-c-field">
          <label for="b-msg">Beskriv dit projekt</label>
          <textarea id="b-msg" name="message" rows="4"></textarea>
        </div>
        <button type="submit" class="b-c-submit">
          Send forespørgsel
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <p class="b-c-privacy">Dine oplysninger bruges kun til at svare på din henvendelse. De videregives ikke.</p>
      </form>
    </div>
  </div>
</section>

<style>
  .b-contact { background: #fbf9f8; padding: 96px 0; }
  .b-c-container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .b-c-grid { display: grid; grid-template-columns: 1fr; gap: 48px; }
  .b-eyebrow { font-family: var(--font-label); font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase; color: #6f4315; display: block; margin-bottom: 16px; }
  .b-h2 { font-family: var(--font-headline); font-size: clamp(1.75rem, 4vw, 2.5rem); line-height: 1.2; color: #1b1c1c; margin: 0 0 16px; font-weight: 500; }
  .b-h2-italic { font-style: italic; color: #6f4315; }
  .b-c-sub { font-family: var(--font-body); font-size: 1.05rem; line-height: 1.7; color: #51443a; margin: 0 0 32px; }

  .b-c-promises { display: flex; flex-direction: column; gap: 16px; margin-bottom: 32px; }
  .b-c-promise { display: flex; gap: 14px; align-items: flex-start; }
  .b-c-check {
    flex-shrink: 0; width: 32px; height: 32px;
    border-radius: 50%; background: #6f4315; color: #fff;
    display: flex; align-items: center; justify-content: center;
  }
  .b-c-promise-t { font-family: var(--font-body); font-weight: 700; color: #1b1c1c; font-size: 1rem; }
  .b-c-promise-m { font-family: var(--font-body); font-size: 0.85rem; color: #51443a; }

  .b-c-direct {
    padding-top: 24px;
    border-top: 1px solid rgba(111,67,21,0.15);
  }
  .b-c-direct-link {
    display: inline-flex; align-items: center; gap: 12px;
    color: #1b1c1c;
  }
  .b-c-direct-link svg { color: #6f4315; }
  .b-c-direct-num { font-family: var(--font-headline); font-style: italic; font-size: 1.75rem; line-height: 1; }
  .b-c-direct-meta { font-family: var(--font-body); font-size: 0.85rem; color: #51443a; margin-top: 2px; }

  .b-c-form {
    background: #fff;
    padding: 32px;
    border-radius: 16px;
    border: 1px solid rgba(111,67,21,0.12);
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    display: flex; flex-direction: column; gap: 18px;
  }
  .b-c-field { display: flex; flex-direction: column; gap: 6px; }
  .b-c-field-row { display: grid; grid-template-columns: 1fr; gap: 18px; }
  .b-c-field label { font-family: var(--font-body); font-size: 0.85rem; font-weight: 700; color: #1b1c1c; }
  .b-c-field input, .b-c-field textarea, .b-c-field select {
    background: #fbf9f8;
    border: 1px solid rgba(111,67,21,0.2);
    padding: 12px 14px;
    border-radius: 10px;
    font-family: var(--font-body);
    font-size: 1rem;
    color: #1b1c1c;
    outline: none;
    transition: border-color 0.3s;
  }
  .b-c-field input:focus, .b-c-field textarea:focus, .b-c-field select:focus { border-color: #6f4315; }
  .b-c-field textarea { resize: vertical; }

  .b-c-submit {
    display: inline-flex; align-items: center; justify-content: center; gap: 12px;
    background: #6f4315; color: #fff;
    padding: 16px 28px;
    font-family: var(--font-body); font-weight: 700;
    font-size: 1.05rem;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    margin-top: 8px;
    transition: transform 0.3s, background 0.3s;
  }
  .b-c-submit:hover { transform: translateY(-2px); background: #8b5a2b; }
  .b-c-privacy { font-family: var(--font-body); font-size: 0.8rem; color: #51443a; margin: 0; text-align: center; }

  @media (min-width: 640px) { .b-c-field-row { grid-template-columns: 1fr 1fr; gap: 18px; } }
  @media (min-width: 1024px) { .b-c-grid { grid-template-columns: 1fr 1fr; gap: 64px; } }
</style>
</content>
</invoke>