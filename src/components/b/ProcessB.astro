---
const steps = [
  { n: '01', t: 'Du sender forespørgsel', b: 'Udfyld formularen eller ring direkte. Vi vender tilbage på hverdage — gratis og uforpligtende, ingen overraskelser bagefter.' },
  { n: '02', t: 'Besigtigelse', b: 'Vi kører ud og ser taget med egne øjne. Vi taler projektet igennem og afdækker behovet ærligt.' },
  { n: '03', t: 'Uforpligtende tilbud', b: 'Du får et gennemskueligt prisoverslag inden for 48 timer — så du hurtigt kan komme videre. Forpligter dig til ingenting før du skriver under.' },
  { n: '04', t: 'Vi går i gang', b: 'Levering inden for 90 dage fra projektstart til færdigt tag. Du ved altid hvor vi er i processen — ingen overraskelser undervejs.' },
  { n: '05', t: 'Aflevering', b: 'Du betaler først når arbejdet er fuldført og godkendt. Vi gennemgår taget, oplærer i vedligehold og udleverer dokumentation.' },
]
---

<section class="b-process" id="proces">
  <div class="b-p-container">
    <div class="b-p-head">
      <span class="b-eyebrow">Sådan kører det</span>
      <h2 class="b-h2">
        Fra forespørgsel til <span class="b-h2-italic">færdigt tag</span> — 5 enkle trin.
      </h2>
      <p class="b-p-lede">
        Gratis besigtigelse, tilbud inden for 48 timer, og du betaler først når arbejdet er godkendt.
      </p>
      <div class="b-p-cta">
        <a href="#kontakt" class="b-p-btn b-p-btn--primary">Hent et tilbud</a>
        <a href="tel:+4524248080" class="b-p-btn b-p-btn--outline">
          <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          24 24 80 80
        </a>
      </div>
    </div>

    <div class="b-p-timeline">
      {steps.map((s) => (
        <div class="b-p-step">
          <div class="b-p-circle">{s.n}</div>
          <div class="b-p-card">
            <h3 class="b-p-title">{s.t}</h3>
            <p class="b-p-body">{s.b}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .b-process { background: #fbf9f8; padding: 96px 0; }
  .b-p-container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  .b-p-head { text-align: center; max-width: 720px; margin: 0 auto 56px; }
  .b-eyebrow { font-family: var(--font-label); font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase; color: #6f4315; display: block; margin-bottom: 16px; }
  .b-h2 { font-family: var(--font-headline); font-size: clamp(1.75rem, 4vw, 2.5rem); line-height: 1.2; color: #1b1c1c; margin: 0 0 16px; font-weight: 500; }
  .b-h2-italic { font-style: italic; color: #6f4315; }

  .b-p-lede {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.6;
    color: #51443a;
    margin: 0 0 28px;
  }

  .b-p-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }
  .b-p-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 28px;
    border-radius: 8px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.98rem;
    text-decoration: none;
    transition: all 0.2s ease;
    min-width: 200px;
  }
  .b-p-btn--primary {
    background: #6f4315;
    color: #fff;
    border: 1px solid #6f4315;
  }
  .b-p-btn--primary:hover {
    background: #5a3410;
    border-color: #5a3410;
  }
  .b-p-btn--outline {
    background: transparent;
    color: #1b1c1c;
    border: 1px solid rgba(111,67,21,0.4);
  }
  .b-p-btn--outline:hover {
    background: rgba(111,67,21,0.06);
    border-color: rgba(111,67,21,0.7);
  }

  .b-p-timeline {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    position: relative;
  }
  .b-p-step {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 20px;
    align-items: start;
    position: relative;
  }
  .b-p-step:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 31px;
    top: 64px;
    bottom: -16px;
    width: 2px;
    background: rgba(111,67,21,0.2);
  }
  .b-p-circle {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: #6f4315;
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-headline);
    font-style: italic;
    font-size: 1.5rem;
    box-shadow: 0 8px 24px rgba(111,67,21,0.25);
  }
  .b-p-card {
    background: #fff;
    padding: 20px 24px;
    border-radius: 12px;
    border: 1px solid rgba(111,67,21,0.12);
    box-shadow: 0 4px 16px rgba(0,0,0,0.04);
  }
  .b-p-title { font-family: var(--font-body); font-weight: 700; font-size: 1.1rem; color: #1b1c1c; margin: 0 0 8px; }
  .b-p-body { font-family: var(--font-body); font-size: 0.95rem; line-height: 1.65; color: #51443a; margin: 0; }

  .b-p-trust {
    margin: 56px auto 0;
    max-width: 760px;
    padding: 20px 28px;
    background: #f4ede2;
    border: 1px solid rgba(111,67,21,0.16);
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    text-align: center;
  }
  .b-p-trust svg {
    flex-shrink: 0;
  }
  .b-p-trust p {
    font-family: var(--font-body);
    font-size: 0.98rem;
    line-height: 1.5;
    color: #51443a;
    margin: 0;
  }
  .b-p-trust strong {
    color: #1b1c1c;
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .b-p-trust {
      border-radius: 12px;
      flex-direction: row;
      padding: 18px 20px;
    }
    .b-p-trust p {
      font-size: 0.92rem;
      text-align: left;
    }
    .b-p-btn { min-width: 0; flex: 1; }
  }
</style>
