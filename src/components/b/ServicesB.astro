---
const services = [
  // Tunge søgeord — Nordsjælland i titlen
  { name: 'Nyt stråtag Nordsjælland', desc: 'Komplet opsætning af nyt stråtag fra bund til top — leveret inden for 90 dage.', img: '/img/straatag1.jpg', href: '/tagdaekning/nyt-straatag/' },
  { name: 'Reparation af stråtag Nordsjælland', desc: 'Punktreparationer og fuld renovering af eksisterende stråtag.', img: '/img/rep_straatag4.jpeg', href: '/tagdaekning/reparation-af-straatag/' },
  // Mindre volumen — Nordsjælland kun i teksten
  { name: 'Mønning & rygning', desc: 'Udskiftning og reparation af mønning for tæt og holdbart stråtag — over hele Nordsjælland.', img: '/img/rygning.jpg', href: '/tagdaekning/monning-til-straatag/' },
  // Tungt søgeord — Nordsjælland i titlen
  { name: 'Algebehandling Nordsjælland', desc: 'Effektiv behandling mod alger og mos der forlænger tagets levetid.', img: '/img/algebehandling2.jpeg', href: '/tagdaekning/aldebehandling-af-straatag/' },
  // Mindre volumen — Nordsjælland kun i teksten
  { name: 'Vedligeholdelse', desc: 'Løbende eftersyn og vedligehold af stråtag i Nordsjælland — så dit tag holder i generationer.', img: '/img/vedligehold1.jpeg', href: '/tagdaekning/vedligeholdelse-af-straatag/' },
  { name: 'Skorstensrenovering', desc: 'Skorstenen er tagets kritiske punkt — vi renoverer og tætner professionelt i hele Nordsjælland.', img: '/img/skorsten3.jpeg', href: '/tagdaekning/skorstensrenovering/' },
]

const extras = [
  { name: 'Rensning af tagrender', href: '/tagdaekning/rensning-af-tagrender/' },
  { name: 'Vinduespolering', href: '/tagdaekning/vinduespolering/' },
  { name: 'Rengøring af solceller', href: '/tagdaekning/rengoring-af-solceller/' },
]
---

<section class="b-services" id="ydelser">
  <div class="b-s-container">
    <div class="b-s-head">
      <span class="b-eyebrow">Hvad vi laver</span>
      <h2 class="b-h2">
        <span class="b-h2-italic">Stråtag-specialister</span> i Nordsjælland — kun stråtag.
      </h2>
      <p class="b-s-sub">
        Vi har lavet hver eneste detalje tusind gange — på stråtage i hele Nordsjælland.
        Det er forskellen på en god tæknings-svend og en generalist der prøver sig frem på dit tag.
      </p>
    </div>

    <div class="b-s-grid">
      {services.map((s) => (
        <a href={s.href} class="b-s-card">
          <div class="b-s-img">
            <img src={s.img} alt={s.name} loading="lazy"/>
          </div>
          <div class="b-s-text">
            <h3 class="b-s-name">{s.name}</h3>
            <p class="b-s-desc">{s.desc}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="b-s-extras">
      <span class="b-s-extras-label">Vi tilbyder også:</span>
      <ul class="b-s-extras-list">
        {extras.map((e) => (
          <li><a href={e.href}>{e.name}</a></li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .b-services { background: #f4ede2; padding: 80px 0 96px; }
  .b-s-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
  .b-s-head { text-align: center; max-width: 720px; margin: 0 auto 56px; }
  .b-eyebrow {
    font-family: var(--font-label); font-size: 11px;
    letter-spacing: 0.32em; text-transform: uppercase;
    color: #a04f1b; display: block; margin-bottom: 16px;
  }
  .b-h2 {
    font-family: var(--font-headline);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.2; color: #1a1310;
    margin: 0 0 16px; font-weight: 500;
  }
  .b-h2-italic { font-style: italic; color: #a04f1b; font-weight: 400; }
  .b-s-sub { font-family: var(--font-body); font-size: 1.05rem; line-height: 1.7; color: #51443a; }

  .b-s-grid { display: grid; grid-template-columns: 1fr; gap: 28px; }
  .b-s-card {
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s, box-shadow 0.3s;
    border: 1px solid rgba(160,79,27,0.12);
    display: flex; flex-direction: column;
  }
  .b-s-card:hover { transform: translateY(-4px); box-shadow: 0 14px 36px rgba(26,19,16,0.1); }

  .b-s-img { aspect-ratio: 16/10; overflow: hidden; }
  .b-s-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s; }
  .b-s-card:hover .b-s-img img { transform: scale(1.04); }

  .b-s-text {
    padding: 28px 28px 32px;
    background: #faf3e7;
    flex: 1;
    display: flex; flex-direction: column;
  }
  .b-s-name {
    font-family: var(--font-headline);
    font-weight: 500;
    font-size: 1.5rem;
    line-height: 1.2;
    color: #1a1310;
    margin: 0 0 12px;
    letter-spacing: -0.005em;
  }
  .b-s-desc {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.6;
    color: #51443a;
    margin: 0;
  }

  @media (min-width: 640px) { .b-s-grid { grid-template-columns: repeat(2, 1fr); gap: 32px; } }
  @media (min-width: 1024px) { .b-s-grid { grid-template-columns: repeat(3, 1fr); } }

  .b-s-extras {
    margin-top: 48px;
    padding: 24px 32px;
    background: rgba(255,255,255,0.6);
    border-radius: 10px;
    display: flex; flex-wrap: wrap; align-items: center; gap: 12px 24px;
    justify-content: center;
  }
  .b-s-extras-label {
    font-family: var(--font-label);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #6f4315;
  }
  .b-s-extras-list { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 8px 20px; }
  .b-s-extras-list a {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: #1b1c1c;
    border-bottom: 1px solid rgba(111,67,21,0.4);
    padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s;
  }
  .b-s-extras-list a:hover { color: #6f4315; border-color: #6f4315; }
</style>
</content>
</invoke>