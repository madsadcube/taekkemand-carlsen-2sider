---
const reviews = [
  { title: 'De holder hvad de lover', text: 'Vi har netop fået nyt stråtag på hovedhuset ved stranden samt pudset annekset af (16 år gammelt). Jeg har fulgt arbejdet på tætteste hold og kan varmt anbefale Jacob og hans team. De har været effektive og dygtige.', name: 'Peter Sonne Christensen', meta: 'Nyt stråtag', rating: 5 },
  { title: 'Super glade…', text: 'Vi har fået nyt tag og er super glade for det arbejde der er blevet lavet. Jacob og Matias er et par flinke fyre og holder hvad de lover. Vi vil helt sikkert anbefale tækkemand Carlsen.', name: 'Christian Pfeil Bendtsen', meta: 'Nyt stråtag', rating: 5 },
  { title: 'Fantastisk stykke arbejde', text: 'Jakob har lavet et fantastisk stykke arbejde. Han er omhyggelig og man mærker at hans faglige stolthed betyder alt for ham. Meget regulær og til at stole på.', name: 'Børge Jensen', meta: 'Mønning', rating: 5 },
  { title: 'Kan varmt anbefales…', text: 'Vi har fået nyt stråtag på vores gamle stuehus. Begge utrolig kompetente, samvittighedsfulde og dygtige til deres håndværk.', name: 'Anne-mette Bøtting Bendtsen', meta: 'Nyt stråtag', rating: 5 },
  { title: 'Dedikerede tækkemænd', text: 'Samarbejdet med Jacob har været helt igennem positivt og fleksibelt, også selv om opgaven blev løst hen over en vinter med frost og sne.', name: 'Thomas Brandt', meta: 'Nyt stråtag', rating: 5 },
  { title: 'Overskueligt tilbud', text: 'Tilbuddet var gennemskueligt og detaljeret. Arbejdet blev udført som aftalt, og vi blev løbende informeret undervejs. Det færdige resultat er virkelig flot.', name: 'Kasper Andreasen', meta: 'Renovering af stråtag', rating: 5 },
]
---

<section class="b-test" id="anmeldelser">
  <div class="b-t-container">
    <div class="b-t-head">
      <div class="b-t-head-text">
        <span class="b-eyebrow">Anmeldelser</span>
        <h2 class="b-h2">
          Vi samler på <span class="b-h2-italic">glade kunder</span>.
        </h2>
      </div>
      <div class="b-t-google" aria-label="5,0 stjerner på Google">
        <div class="b-t-google-logo">
          <svg viewBox="0 0 24 24" width="32" height="32" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.99.66-2.25 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
        </div>
        <div>
          <div class="b-t-google-stars">★★★★★ <strong>5,0</strong></div>
          <div class="b-t-google-label">Google Anmeldelser</div>
        </div>
      </div>
    </div>

    <div class="b-t-grid">
      {reviews.map((r) => (
        <article class="b-t-card">
          <div class="b-t-stars">{'★'.repeat(r.rating)}</div>
          <h3 class="b-t-title">"{r.title}"</h3>
          <p class="b-t-text">{r.text}</p>
          <div class="b-t-attr">
            <div class="b-t-name">{r.name}</div>
            <div class="b-t-meta">{r.meta}</div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .b-test { background: #f4ede2; padding: 96px 0; }
  .b-t-container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
  .b-t-head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 56px;
  }
  .b-t-head-text { max-width: 720px; }
  .b-eyebrow { font-family: var(--font-label); font-size: 11px; letter-spacing: 0.32em; text-transform: uppercase; color: #a04f1b; display: block; margin-bottom: 16px; }
  .b-h2 { font-family: var(--font-headline); font-size: clamp(1.75rem, 4vw, 2.5rem); line-height: 1.2; color: #1a1310; margin: 0; font-weight: 500; }
  .b-h2-italic { font-style: italic; color: #a04f1b; }

  .b-t-google {
    display: inline-flex; align-items: center; gap: 12px;
    padding: 12px 18px;
    background: #fff;
    border-radius: 10px;
    border: 1px solid rgba(160,79,27,0.12);
    box-shadow: 0 4px 14px rgba(26,19,16,0.06);
  }
  .b-t-google-logo { display: inline-flex; }
  .b-t-google-stars { font-family: var(--font-body); color: #d4a017; font-size: 0.95rem; letter-spacing: 1px; }
  .b-t-google-stars strong { color: #1a1310; margin-left: 6px; font-weight: 700; letter-spacing: 0; }
  .b-t-google-label { font-family: var(--font-body); font-size: 0.78rem; color: #51443a; margin-top: 2px; }

  @media (min-width: 768px) {
    .b-t-head { flex-direction: row; align-items: flex-end; }
  }

  .b-t-platforms { display: inline-flex; align-items: center; flex-wrap: wrap; gap: 16px; padding: 16px 24px; background: #fff; border-radius: 999px; box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
  .b-platform { text-align: center; }
  .b-stars { color: #d4a017; font-size: 1rem; letter-spacing: 1px; line-height: 1; }
  .b-platform-name { font-family: var(--font-body); font-size: 0.85rem; font-weight: 700; color: #1b1c1c; margin-top: 4px; }
  .b-platform-divider { width: 1px; height: 28px; background: rgba(111,67,21,0.2); }

  .b-t-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  .b-t-card {
    background: #fff;
    padding: 28px;
    border-radius: 16px;
    border: 1px solid rgba(111,67,21,0.1);
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .b-t-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(0,0,0,0.08); }
  .b-t-stars { color: #d4a017; font-size: 1.05rem; letter-spacing: 2px; margin-bottom: 14px; }
  .b-t-title {
    font-family: var(--font-headline);
    font-style: italic;
    font-size: 1.15rem;
    color: #1a1310;
    margin: 0 0 10px;
    font-weight: 500;
    line-height: 1.25;
  }
  .b-t-text { font-family: var(--font-body); font-size: 0.95rem; line-height: 1.65; color: #51443a; margin: 0 0 20px; }
  .b-t-attr { padding-top: 16px; border-top: 1px solid rgba(111,67,21,0.15); }
  .b-t-name { font-family: var(--font-body); font-weight: 700; font-size: 0.95rem; color: #1b1c1c; }
  .b-t-meta { font-family: var(--font-body); font-size: 0.82rem; color: #51443a; margin-top: 2px; }

  @media (min-width: 640px) { .b-t-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .b-t-grid { grid-template-columns: repeat(3, 1fr); gap: 28px; } }
</style>
</content>
</invoke>