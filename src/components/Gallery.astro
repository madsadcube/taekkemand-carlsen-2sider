---
---

<section id="billeder" class="py-24" style="background: linear-gradient(180deg, #fff 0%, rgba(235,207,162,0.50) 100%); position: relative; overflow: hidden;">
  <div class="max-w-7xl mx-auto px-8">

    <div class="flex justify-between items-end mb-16">
      <div>
        <span class="text-xs font-bold uppercase tracking-widest" style="color: var(--color-secondary); font-family: var(--font-label); letter-spacing: 0.3em;">Portefølje</span>
        <h2 class="mt-4" style="font-family: var(--font-headline); font-size: clamp(2rem, 4vw, 3.2rem); color: #431a06;">
          Kvalitet i alle detaljer
        </h2>
      </div>
      <div class="hidden md:block">
        <p class="text-right max-w-xs text-sm leading-relaxed" style="color: var(--color-outline); font-family: var(--font-body);">
          Vi betjener kunder i hele Danmark med fokus på holdbarhed og æstetik.
        </p>
      </div>
    </div>

    <!-- Mobile slider -->
    <div class="relative md:hidden">
      <div id="gallery-mobile-slider" class="flex gap-4 overflow-x-auto snap-x snap-mandatory pb-2 -mx-2 px-2">
        <div class="w-[86vw] max-w-[420px] shrink-0 snap-start group cursor-pointer relative overflow-hidden rounded-lg">
          <img class="w-full object-cover transition-transform duration-1000 group-hover:scale-105" style="height: 380px;" src="/img/fb_straatag1.jpg" alt="Nyt stråtag på stor ejendom" loading="lazy" decoding="async" />
        </div>
        <div class="w-[86vw] max-w-[420px] shrink-0 snap-start group cursor-pointer relative overflow-hidden rounded-lg">
          <img class="w-full object-cover transition-transform duration-1000 group-hover:scale-105" style="height: 380px;" src="/img/reparation3.webp" alt="Klassisk stråtag reparation" loading="lazy" decoding="async" />
        </div>
        <div class="w-[86vw] max-w-[420px] shrink-0 snap-start group cursor-pointer relative overflow-hidden rounded-lg">
          <img class="w-full object-cover transition-transform duration-1000 group-hover:scale-105" style="height: 380px;" src="/img/fb_projekt1.jpg" alt="Stråtag projekt" loading="lazy" decoding="async" />
        </div>
        <div class="w-[86vw] max-w-[420px] shrink-0 snap-start group cursor-pointer relative overflow-hidden rounded-lg">
          <img class="w-full object-cover transition-transform duration-1000 group-hover:scale-105" style="height: 380px;" src="/img/fb_projekt2.jpg" alt="Stråtag projekt" loading="lazy" decoding="async" />
        </div>
        <div class="w-[86vw] max-w-[420px] shrink-0 snap-start group cursor-pointer relative overflow-hidden rounded-lg">
          <img class="w-full object-cover transition-transform duration-1000 group-hover:scale-105" style="height: 380px;" src="/img/fb_projekt3.jpg" alt="Stråtag projekt" loading="lazy" decoding="async" />
        </div>
        <div class="w-[86vw] max-w-[420px] shrink-0 snap-start group cursor-pointer relative overflow-hidden rounded-lg">
          <img class="w-full object-cover transition-transform duration-1000 group-hover:scale-105" style="height: 380px;" src="/img/fb_projekt4.jpg" alt="Stråtag projekt" loading="lazy" decoding="async" />
        </div>
        <div class="w-[86vw] max-w-[420px] shrink-0 snap-start group cursor-pointer relative overflow-hidden rounded-lg">
          <img class="w-full object-cover transition-transform duration-1000 group-hover:scale-105" style="height: 380px;" src="/img/fb_projekt5.jpg" alt="Stråtag projekt" loading="lazy" decoding="async" />
        </div>
      </div>

      <div class="flex justify-center gap-3 mt-4">
        <button type="button" data-slider-target="gallery-mobile-slider" data-direction="prev" class="w-10 h-10 rounded-full flex items-center justify-center" style="background: #fff; border: 1px solid var(--color-outline-variant); color: #431a06;" aria-label="Forrige">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button type="button" data-slider-target="gallery-mobile-slider" data-direction="next" class="w-10 h-10 rounded-full flex items-center justify-center" style="background: #fff; border: 1px solid var(--color-outline-variant); color: #431a06;" aria-label="Næste">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Desktop grid -->
    <div class="hidden md:grid md:grid-cols-12 gap-6">

      <!-- Large image -->
      <div class="md:col-span-8 group cursor-pointer relative overflow-hidden rounded-lg">
        <img class="w-full object-cover transition-transform duration-1000 group-hover:scale-105" style="height: 500px;" src="/img/fb_straatag1.jpg" alt="Nyt stråtag på stor ejendom" loading="lazy" decoding="async" />
        <div class="absolute inset-0 flex flex-col justify-end p-8 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 60%);">
          <span class="text-sm uppercase tracking-widest mb-2" style="color: #ffdcc1; font-family: var(--font-label);">Større Ejendom · Helsinge</span>
          <h3 class="text-white" style="font-family: var(--font-headline); font-size: 1.8rem;">Nyt stråtag på herskabsvilla</h3>
        </div>
      </div>

      <!-- Small image top-right -->
      <div class="md:col-span-4 group cursor-pointer relative overflow-hidden rounded-lg">
        <img class="w-full object-cover transition-transform duration-1000 group-hover:scale-105" style="height: 500px;" src="/img/reparation3.webp" alt="Klassisk stråtag reparation" loading="lazy" decoding="async" />
        <div class="absolute inset-0 flex flex-col justify-end p-8 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 60%);">
          <span class="text-sm uppercase tracking-widest mb-2" style="color: #ffdcc1; font-family: var(--font-label);">Reparation · Hillerød</span>
          <h3 class="text-white" style="font-family: var(--font-headline); font-size: 1.8rem;">Klassisk stråtag</h3>
        </div>
      </div>

      <!-- Row 2: 3 equal columns -->
      <div class="md:col-span-4 group cursor-pointer relative overflow-hidden rounded-lg">
        <img class="w-full object-cover transition-transform duration-1000 group-hover:scale-105" style="height: 360px;" src="/img/fb_projekt1.jpg" alt="Stråtag projekt" loading="lazy" decoding="async" />
        <div class="absolute inset-0 flex flex-col justify-end p-6 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 60%);">
          <h3 class="text-white" style="font-family: var(--font-headline); font-size: 1.4rem;">Nyt stråtag</h3>
        </div>
      </div>
      <div class="md:col-span-4 group cursor-pointer relative overflow-hidden rounded-lg">
        <img class="w-full object-cover transition-transform duration-1000 group-hover:scale-105" style="height: 360px;" src="/img/fb_projekt2.jpg" alt="Stråtag projekt" loading="lazy" decoding="async" />
        <div class="absolute inset-0 flex flex-col justify-end p-6 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 60%);">
          <h3 class="text-white" style="font-family: var(--font-headline); font-size: 1.4rem;">Mønning</h3>
        </div>
      </div>
      <div class="md:col-span-4 group cursor-pointer relative overflow-hidden rounded-lg">
        <img class="w-full object-cover transition-transform duration-1000 group-hover:scale-105" style="height: 360px;" src="/img/fb_projekt3.jpg" alt="Stråtag projekt" loading="lazy" decoding="async" />
        <div class="absolute inset-0 flex flex-col justify-end p-6 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 60%);">
          <h3 class="text-white" style="font-family: var(--font-headline); font-size: 1.4rem;">Renovering</h3>
        </div>
      </div>

      <!-- Row 3: small + large -->
      <div class="md:col-span-4 group cursor-pointer relative overflow-hidden rounded-lg">
        <img class="w-full object-cover transition-transform duration-1000 group-hover:scale-105" style="height: 400px;" src="/img/fb_projekt4.jpg" alt="Stråtag projekt" loading="lazy" decoding="async" />
        <div class="absolute inset-0 flex flex-col justify-end p-6 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 60%);">
          <h3 class="text-white" style="font-family: var(--font-headline); font-size: 1.4rem;">Rygning</h3>
        </div>
      </div>
      <div class="md:col-span-8 group cursor-pointer relative overflow-hidden rounded-lg">
        <img class="w-full object-cover transition-transform duration-1000 group-hover:scale-105" style="height: 400px;" src="/img/fb_projekt5.jpg" alt="Stråtag projekt" loading="lazy" decoding="async" />
        <div class="absolute inset-0 flex flex-col justify-end p-8 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 60%);">
          <span class="text-sm uppercase tracking-widest mb-2" style="color: #ffdcc1; font-family: var(--font-label);">Renovering · Nordsjælland</span>
          <h3 class="text-white" style="font-family: var(--font-headline); font-size: 1.8rem;">Fuld tagrenovering</h3>
        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
  requestAnimationFrame(() => {
    const gallerySlider = document.getElementById('gallery-mobile-slider');
    const galleryButtons = document.querySelectorAll('[data-slider-target="gallery-mobile-slider"]');

    if (gallerySlider && galleryButtons.length > 0) {
      const getScrollStep = () => {
        const firstCard = gallerySlider.children[0];
        if (!firstCard) return 320;
        const styles = window.getComputedStyle(gallerySlider);
        const gap = parseFloat(styles.columnGap || styles.gap || '16');
        return firstCard.getBoundingClientRect().width + gap;
      };

      galleryButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const direction = button.getAttribute('data-direction') === 'prev' ? -1 : 1;
          const step = getScrollStep();
          const maxScroll = gallerySlider.scrollWidth - gallerySlider.clientWidth;
          if (direction === 1 && gallerySlider.scrollLeft >= maxScroll - 4) {
            gallerySlider.scrollTo({ left: 0, behavior: 'instant' });
            gallerySlider.scrollBy({ left: step, behavior: 'smooth' });
          } else if (direction === -1 && gallerySlider.scrollLeft <= 4) {
            gallerySlider.scrollTo({ left: maxScroll, behavior: 'instant' });
            gallerySlider.scrollBy({ left: -step, behavior: 'smooth' });
          } else {
            gallerySlider.scrollBy({ left: direction * step, behavior: 'smooth' });
          }
        });
      });
    }
  });
</script>
