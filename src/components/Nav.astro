---
import { cities } from '../data/cities'

// Service grouping for the Ydelser dropdown
const stratag = [
  { title: 'Nyt stråtag', href: '/tagdaekning/nyt-straatag/' },
  { title: 'Reparation af stråtag', href: '/tagdaekning/reparation-af-straatag/' },
  { title: 'Mønning til stråtag', href: '/tagdaekning/monning-til-straatag/' },
  { title: 'Renovering af stråtag', href: '/tagdaekning/renovering-af-straatag/' },
  { title: 'Reparation af rygning', href: '/tagdaekning/reparation-af-rygning/' },
  { title: 'Vedligeholdelse', href: '/tagdaekning/vedligeholdelse-af-straatag/' },
]

const behandling = [
  { title: 'Algebehandling', href: '/tagdaekning/aldebehandling-af-straatag/' },
  { title: 'Mosafrensning', href: '/tagdaekning/mosafrensning/' },
  { title: 'Mosbehandling', href: '/tagdaekning/mosbehandling-paa-straatag/' },
  { title: 'Holdbarhed af stråtag', href: '/tagdaekning/holdbarhed-af-straatag/' },
]

const andet = [
  { title: 'Skorstensrenovering', href: '/tagdaekning/skorstensrenovering/' },
  { title: 'Taginspektion', href: '/tagdaekning/taginspektion/' },
  { title: 'Rensning af tagrender', href: '/tagdaekning/rensning-af-tagrender/' },
]

// Sorter byer alfabetisk for menu
const sortedCities = [...cities].sort((a, b) => a.name.localeCompare(b.name, 'da'))
---

<nav class="fixed top-0 w-full z-50" style="background: rgba(251,249,248,0.92); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(213,195,182,0.3);">
  <div class="flex justify-between items-center max-w-7xl mx-auto px-8 py-5">
    <a href="/" class="flex-shrink-0">
      <img src="/img/logo-dark.webp" alt="Tækkemand Carlsen" class="h-10 w-auto" width="200" height="60" decoding="async" />
    </a>

    <ul class="hidden lg:flex items-center gap-7 text-base" style="font-family: var(--font-headline); color: #51443a;">

      <li><a href="/" class="nav-link">Forside</a></li>

      <!-- Om os -->
      <li class="relative group">
        <button type="button" class="nav-link flex items-center gap-1" aria-haspopup="true" aria-expanded="false">
          Om os
          <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="dropdown" role="menu">
          <a href="/om-os/" class="dropdown-link">Om virksomheden</a>
          <a href="/priser/" class="dropdown-link">Priser</a>
          <a href="/garanti/" class="dropdown-link">Garanti</a>
        </div>
      </li>

      <!-- Ydelser (mega dropdown) -->
      <li class="static group">
        <button type="button" class="nav-link flex items-center gap-1" aria-haspopup="true" aria-expanded="false">
          Ydelser
          <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mega-dropdown" role="menu">
          <div class="grid grid-cols-3 gap-8 px-8 py-6 max-w-5xl mx-auto">
            <div>
              <div class="mega-heading">Stråtag-arbejde</div>
              {stratag.map(s => <a href={s.href} class="mega-link">{s.title}</a>)}
            </div>
            <div>
              <div class="mega-heading">Behandling</div>
              {behandling.map(s => <a href={s.href} class="mega-link">{s.title}</a>)}
            </div>
            <div>
              <div class="mega-heading">Specialopgaver</div>
              {andet.map(s => <a href={s.href} class="mega-link">{s.title}</a>)}
            </div>
          </div>
          <div class="border-t border-gray-200 px-8 py-3 bg-gray-50 text-center">
            <a href="/tagdaekning/" class="text-sm font-semibold" style="color: #6f4315; font-family: var(--font-body); font-style: normal;">Se alle ydelser →</a>
          </div>
        </div>
      </li>

      <li><a href="/galleri/" class="nav-link">Galleri</a></li>
      <li><a href="/anmeldelser/" class="nav-link">Anmeldelser</a></li>

      <!-- Områder -->
      <li class="relative group">
        <button type="button" class="nav-link flex items-center gap-1" aria-haspopup="true" aria-expanded="false">
          Områder
          <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="dropdown" role="menu">
          {sortedCities.map(c => <a href={`/${c.slug}/`} class="dropdown-link">{c.name}</a>)}
          <div class="border-t border-gray-200 mt-2 pt-2">
            <a href="/omraader/" class="dropdown-link" style="font-weight: 600; color: #6f4315;">Alle områder →</a>
          </div>
        </div>
      </li>

      <li><a href="/kontakt/" class="nav-link">Kontakt</a></li>
    </ul>

    <a
      href="tel:+4524248080"
      class="hidden lg:flex items-center gap-2 px-5 py-2 rounded-lg font-bold transition-all flex-shrink-0"
      style="background: #6f4315; color: #fff; font-family: var(--font-body); font-size: 0.95rem;"
      onmouseover="this.style.background='#8b5a2b'" onmouseout="this.style.background='#6f4315'"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
      </svg>
      24 24 80 80
    </a>

    <!-- Hamburger -->
    <button id="menu-btn" class="lg:hidden p-2" aria-label="Menu">
      <svg class="w-6 h-6" style="color:#1b1c1c" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="icon-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        <path id="icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden px-8 pb-6 space-y-1 overflow-y-auto" style="max-height: calc(100vh - 80px); border-top: 1px solid rgba(213,195,182,0.4);">
    <a href="/" class="mob-link">Forside</a>

    <details class="mob-group">
      <summary class="mob-link mob-summary">Om os</summary>
      <a href="/om-os/" class="mob-sublink">Om virksomheden</a>
      <a href="/priser/" class="mob-sublink">Priser</a>
      <a href="/garanti/" class="mob-sublink">Garanti</a>
    </details>

    <details class="mob-group">
      <summary class="mob-link mob-summary">Ydelser</summary>
      <div class="mob-section">Stråtag-arbejde</div>
      {stratag.map(s => <a href={s.href} class="mob-sublink">{s.title}</a>)}
      <div class="mob-section">Behandling</div>
      {behandling.map(s => <a href={s.href} class="mob-sublink">{s.title}</a>)}
      <div class="mob-section">Specialopgaver</div>
      {andet.map(s => <a href={s.href} class="mob-sublink">{s.title}</a>)}
      <a href="/tagdaekning/" class="mob-sublink" style="font-weight:600;">Se alle ydelser →</a>
    </details>

    <a href="/galleri/" class="mob-link">Galleri</a>
    <a href="/anmeldelser/" class="mob-link">Anmeldelser</a>

    <details class="mob-group">
      <summary class="mob-link mob-summary">Områder</summary>
      {sortedCities.map(c => <a href={`/${c.slug}/`} class="mob-sublink">{c.name}</a>)}
      <a href="/omraader/" class="mob-sublink" style="font-weight:600;">Alle områder →</a>
    </details>

    <a href="/kontakt/" class="mob-link">Kontakt</a>

    <a href="tel:+4524248080" class="block text-center mt-4 py-3 px-6 rounded-lg font-bold text-sm uppercase tracking-widest" style="background: #6f4315; color: #fff; font-family: var(--font-label);">24 24 80 80</a>
  </div>
</nav>

<style>
  .nav-link {
    color: #51443a;
    transition: color 200ms ease;
    cursor: pointer;
    background: transparent;
    border: none;
    font: inherit;
    padding: 0.25rem 0;
  }
  .nav-link:hover { color: #6f4315; }

  /* Standard dropdown (Om os, Områder) */
  .dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    background: #fff;
    border: 1px solid rgba(213,195,182,0.4);
    border-radius: 8px;
    box-shadow: 0 12px 32px rgba(0,0,0,0.08);
    padding: 0.5rem 0;
    min-width: 220px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 180ms ease, visibility 180ms ease, transform 180ms ease;
    z-index: 60;
    font-style: normal;
  }
  .group:hover .dropdown,
  .group:focus-within .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  .dropdown-link {
    display: block;
    padding: 0.55rem 1.25rem;
    color: #1b1c1c;
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: background 150ms ease, color 150ms ease;
  }
  .dropdown-link:hover { background: #faf6f1; color: #6f4315; }

  /* Mega dropdown (Ydelser) */
  .mega-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: #fff;
    border-top: 1px solid rgba(213,195,182,0.4);
    box-shadow: 0 16px 40px rgba(0,0,0,0.08);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity 200ms ease, visibility 200ms ease, transform 200ms ease;
    z-index: 60;
    font-style: normal;
  }
  .group:hover .mega-dropdown,
  .group:focus-within .mega-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .mega-heading {
    font-family: var(--font-headline);
    font-style: italic;
    color: #6f4315;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding-bottom: 0.5rem;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid rgba(213,195,182,0.4);
  }
  .mega-link {
    display: block;
    padding: 0.35rem 0;
    color: #1b1c1c;
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: color 150ms ease;
  }
  .mega-link:hover { color: #6f4315; }

  /* Mobile */
  .mob-link {
    display: block;
    padding: 0.85rem 0;
    color: #1b1c1c;
    font-family: var(--font-headline);
    font-size: 1.15rem;
    border-bottom: 1px solid rgba(213,195,182,0.25);
  }
  .mob-summary { cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .mob-summary::after { content: '+'; font-size: 1.4rem; font-style: normal; color: #6f4315; }
  details[open] .mob-summary::after { content: '−'; }
  .mob-sublink {
    display: block;
    padding: 0.55rem 0 0.55rem 1rem;
    color: #51443a;
    font-family: var(--font-body);
    font-size: 0.95rem;
  }
  .mob-section {
    padding: 0.75rem 0 0.25rem;
    font-family: var(--font-headline);
    font-style: italic;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #6f4315;
  }
</style>

<script>
  const btn = document.getElementById('menu-btn')!
  const menu = document.getElementById('mobile-menu')!
  const open = document.getElementById('icon-open')!
  const close = document.getElementById('icon-close')!
  btn.addEventListener('click', () => {
    const hidden = menu.classList.toggle('hidden')
    open.classList.toggle('hidden', !hidden)
    close.classList.toggle('hidden', hidden)
  })
</script>
