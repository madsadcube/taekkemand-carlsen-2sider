---
import '../styles/global.css'

interface Props {
  title: string
  description: string
  canonical?: string
  city?: string
}

const {
  title,
  description,
  canonical = 'https://taekkemandcarlsen.dk/',
  city,
} = Astro.props

const siteUrl = 'https://taekkemandcarlsen.dk'
const businessId = `${siteUrl}/#business`
const websiteId = `${siteUrl}/#website`

const graph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": websiteId,
      "url": siteUrl,
      "name": "Tækkemand Carlsen",
      "publisher": { "@id": businessId },
      "potentialAction": {
        "@type": "SearchAction",
        "target": { "@type": "EntryPoint", "urlTemplate": `${siteUrl}/?s={search_term_string}` },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": ["LocalBusiness", "RoofingContractor"],
      "@id": businessId,
      "name": "Tækkemand Carlsen",
      "url": siteUrl,
      "logo": {
        "@type": "ImageObject",
        "url": `${siteUrl}/img/logo.png`,
        "width": 200,
        "height": 60
      },
      "image": `${siteUrl}/img/og-image.jpg`,
      "description": "Professionel tækkemand i Nordsjælland med over 50 års erfaring. Speciale i nyt stråtag, renovering, mønning, algebehandling og vedligehold. Betjener hele Nordsjælland — Helsinge, Hillerød, Gilleleje, Frederiksværk, Tisvildeleje og Hundested.",
      "telephone": "+4524248080",
      "email": "post@taekkemandcarlsen.dk",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Nørretorv 30",
        "addressLocality": "Ringsted",
        "postalCode": "4100",
        "addressCountry": "DK"
      },
      "openingHoursSpecification": [{
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "08:00",
        "closes": "16:00"
      }],
      "areaServed": city
        ? { "@type": "City", "name": city }
        : { "@type": "AdministrativeArea", "name": "Nordsjælland" },
      "sameAs": [
        "https://www.facebook.com/taekkemandcarlsen",
        "https://www.instagram.com/taekkemandcarlsen"
      ]
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": title,
      "description": description,
      "isPartOf": { "@id": websiteId },
      "about": { "@id": businessId }
    }
  ]
}
---

<!doctype html>
<html lang="da-DK">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Preload LCP hero image — must be first so browser discovers it immediately -->
    <link rel="preload" as="image" href="/img/straatag1-hero.webp" fetchpriority="high" type="image/webp" />

    <!-- Fonts preconnect — early as possible -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={canonical.includes('vercel.app') ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://taekkemandcarlsen.dk/img/og-image.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Tækkemand Carlsen — professionelt stråtag i Nordsjælland" />
    <meta property="og:site_name" content="Tækkemand Carlsen" />
    <meta property="og:locale" content="da_DK" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://taekkemandcarlsen.dk/img/og-image.jpg" />

    <!-- Sitemap + llms.txt discovery -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Fonts — non-blocking load -->
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Manrope:wght@200..800&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Manrope:wght@200..800&display=swap" rel="stylesheet" /></noscript>

    <!-- Schema.org JSON-LD @graph -->
    <script type="application/ld+json" set:html={JSON.stringify(graph)} />

    <!-- Google Tag Manager — deferred so it doesn't block LCP -->
    <script>
      window.addEventListener('load', function() {
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-NQZXR4D6');
      });
    </script>
  </head>
  <body>
    <!-- GTM noscript -->
    <noscript>
      <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NQZXR4D6"
        height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>

    <main>
      <slot />
    </main>
  </body>
</html>
